# Environment Variables Reference
# Copy this file to .env and fill in your values for local development.
# On Azure App Service, set these as Application Settings (NOT committed to git).

# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# The canonical URL of your deployed app (no trailing slash)
# Local: http://localhost:3000
# Azure: https://your-app-name.azurewebsites.net
NEXTAUTH_URL="https://your-app-name.azurewebsites.net"

# Random secret for signing NextAuth JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ─── Optional: OAuth Providers ───────────────────────────────────────────────
# Uncomment and fill in if using Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Uncomment and fill in if using GitHub OAuth
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
